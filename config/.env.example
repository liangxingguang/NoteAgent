# NoteAgents Configuration
# 复制此文件为 .env 并填入实际配置

# === Telegram Configuration ===
# 是否启用 Telegram（设置为 true 或 false）
TG_ENABLED=true

# Telegram Bot Token，从 @BotFather 获取
TG_BOT_TOKEN=your_telegram_bot_token_here

# 允许使用的用户ID列表，逗号分隔
# 获取方法：给机器人发送消息，查看日志中的user_id，或使用 @userinfobot
ALLOWED_USER_IDS=123456789,987654321

# Telegram 代理配置（可选）
TG_USE_PROXY=false
TG_PROXY_URL=http://127.0.0.1:7890

# Telegram Webhook 配置（可选）
# 启用 Webhook 模式（推荐生产环境使用）
TG_USE_WEBHOOK=false

# Webhook 回调 URL（需要 HTTPS，开发可用 ngrok 等）
TG_WEBHOOK_URL=https://your-domain.com/telegram/webhook

# Webhook 服务器监听地址和端口
TG_WEBHOOK_HOST=0.0.0.0
TG_WEBHOOK_PORT=8443  # 支持端口: 443, 80, 88, 8443

# Webhook 密钥（可选，用于验证请求）
TG_WEBHOOK_SECRET=your_secret_key_here

# 轮询模式配置（当 Webhook 禁用时使用）
TG_POLL_INTERVAL=1.0
TG_POLL_TIMEOUT=20

# === AI Configuration ===
# AI API Key
AI_API_KEY=your_ai_api_key_here

# AI Model
# 通义千问: qwen-turbo, qwen-plus, qwen-max
# OpenAI: gpt-3.5-turbo, gpt-4
AI_MODEL=qwen-turbo

# AI API Base URL
# 通义千问兼容模式: https://dashscope.aliyuncs.com/compatible-mode/v1
# OpenAI: https://api.openai.com/v1
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# AI Temperature (0.0-2.0)
AI_TEMPERATURE=0.7

# AI Max Tokens
AI_MAX_TOKENS=2000

# === Obsidian Configuration ===
# Obsidian知识库目录路径（绝对路径）
# Linux/Mac示例: /home/username/Obsidian/MyNotes
# Windows示例: C:\Users\username\Obsidian\MyNotes
OBSIDIAN_VAULT_PATH=/path/to/your/obsidian/vault

# === System Configuration ===
# Log Level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Temporary Files Directory
TEMP_DIR=storage/temp_files

# Logs Directory
LOG_DIR=storage/logs

# File Size Limit (bytes, default 50MB)
MAX_FILE_SIZE=52428800

# Text Length Limit (chars, default 5000)
MAX_TEXT_LENGTH=5000

# === 飞书 Configuration ===
# 是否启用飞书功能
FEISHU_ENABLED=false

# 飞书应用凭证（从飞书开放平台获取）
# 访问 https://open.feishu.cn/ 创建自建应用
FEISHU_APP_ID=cli_xxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxx

# 飞书事件订阅配置（Webhook 模式需要）
FEISHU_VERIFICATION_TOKEN=xxxxxxxxxxxxx
FEISHU_ENCRYPT_KEY=xxxxxxxxxxxxx

# 机器人名称
FEISHU_BOT_NAME=NoteAgents

# 飞书允许的用户 ID 列表（open_id，逗号分隔）
# 获取方法：给飞书机器人发消息，查看日志中的 user_id（ou_ 开头）
FEISHU_ALLOWED_USER_IDS=ou_xxxxxxxxxxxxx,ou_yyyyyyyyyyyyy

# 飞书轮询间隔（秒）
FEISHU_POLL_INTERVAL=1.0

# 是否使用 Webhook 模式（需要公网 IP）
FEISHU_USE_WEBHOOK=false
FEISHU_WEBHOOK_HOST=0.0.0.0
FEISHU_WEBHOOK_PORT=8000

# === LLM Wiki Configuration ===
# LLM Wiki 功能开关
WIKI_ENABLED=false

# Wiki 数据存放目录（可自定义）
WIKI_DATA_ROOT=wiki_data/

# 归档策略：daily（按日归档）或 monthly（按月归档）
WIKI_ARCHIVE_STRATEGY=daily

# Wiki 使用的 LLM 配置（默认复用 AI 配置）
# WIKI_LLM_API_KEY=your_wiki_llm_api_key_here
# WIKI_LLM_MODEL=qwen-turbo
# WIKI_LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# WIKI_LLM_TEMPERATURE=0.7
# WIKI_LLM_MAX_TOKENS=2000
# WIKI_LLM_RETRY_TIMES=3

# 是否自动整理笔记
WIKI_AUTO_PROCESS=true

# 是否自动导入到 Wiki 知识网络
WIKI_AUTO_IMPORT_WIKI=false

# 文件监控配置
WIKI_FILE_MONITOR_ENABLED=true
WIKI_FILE_MONITOR_INTERVAL=5

# 健康检查间隔（天）
WIKI_HEALTH_CHECK_INTERVAL=7
