# NoteAgents Configuration
# 复制此文件为 .env 并填入实际配置

# === Telegram Configuration ===
# Telegram Bot Token，从 @BotFather 获取
TG_BOT_TOKEN=your_telegram_bot_token_here

# 允许使用的用户ID列表，逗号分隔
# 获取方法：给机器人发送消息，查看日志中的user_id，或使用 @userinfobot
ALLOWED_USER_IDS=123456789,987654321

# === AI Configuration ===
# AI API Key
AI_API_KEY=your_ai_api_key_here

# AI Model
# 通义千问: qwen-turbo, qwen-plus, qwen-max
# OpenAI: gpt-3.5-turbo, gpt-4
AI_MODEL=qwen-turbo

# AI API Base URL
# 通义千问兼容模式: https://dashscope.aliyuncs.com/compatible-mode/v1
# OpenAI: https://api.openai.com/v1
AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1

# AI Temperature (0.0-2.0)
AI_TEMPERATURE=0.7

# AI Max Tokens
AI_MAX_TOKENS=2000

# === Obsidian Configuration ===
# Obsidian知识库目录路径（绝对路径）
# Linux/Mac示例: /home/username/Obsidian/MyNotes
# Windows示例: C:\Users\username\Obsidian\MyNotes
OBSIDIAN_VAULT_PATH=/path/to/your/obsidian/vault

# === System Configuration ===
# Log Level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Temporary Files Directory
TEMP_DIR=storage/temp_files

# Logs Directory
LOG_DIR=storage/logs

# File Size Limit (bytes, default 50MB)
MAX_FILE_SIZE=52428800

# Text Length Limit (chars, default 5000)
MAX_TEXT_LENGTH=5000
