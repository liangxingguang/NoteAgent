# NoteAgents 环境变量配置
# 请复制此文件为 .env 并填入您的配置

# Telegram Bot 配置
# 是否启用 Telegram（设置为 true 或 false）
TG_ENABLED=true

TG_BOT_TOKEN=your_telegram_bot_token_here
ALLOWED_USER_IDS=123456789,987654321

# Telegram 代理配置（可选）
TG_USE_PROXY=false
TG_PROXY_URL=http://127.0.0.1:7890

# Telegram Webhook 配置（可选）
TG_USE_WEBHOOK=false
TG_WEBHOOK_URL=https://your-domain.com/telegram/webhook
TG_WEBHOOK_HOST=0.0.0.0
TG_WEBHOOK_PORT=8443
TG_WEBHOOK_SECRET=your_secret_key_here
TG_POLL_INTERVAL=1.0
TG_POLL_TIMEOUT=20

# AI API 配置
AI_API_KEY=your_ai_api_key_here
AI_MODEL=ark-code-latest
AI_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
AI_TEMPERATURE=0.7
AI_MAX_TOKENS=2000

# Obsidian 配置
OBSIDIAN_VAULT_PATH=D:/Obsidian/Vault

# GitHub 配置（可选）
# GITHUB_ENABLED=false
# GITHUB_TOKEN=your_github_token_here
# GITHUB_OWNER=your_github_username
# GITHUB_REPO=notes-backup
# GITHUB_BRANCH=main

# 系统配置
LOG_LEVEL=INFO
TEMP_DIR=storage/temp_files
LOG_DIR=storage/logs

# 飞书配置（可选）
FEISHU_ENABLED=false
FEISHU_APP_ID=cli_xxxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxx
FEISHU_VERIFICATION_TOKEN=xxxxxxxxxxxxx
FEISHU_ENCRYPT_KEY=xxxxxxxxxxxxx
FEISHU_BOT_NAME=NoteAgents
FEISHU_ALLOWED_USER_IDS=ou_xxxxxxxxxxxxx,ou_yyyyyyyyyyyyy
FEISHU_POLL_INTERVAL=1.0
FEISHU_USE_WEBHOOK=false
FEISHU_WEBHOOK_HOST=0.0.0.0
FEISHU_WEBHOOK_PORT=8000

# LLM Wiki 配置
WIKI_ENABLED=false
WIKI_ARCHIVE_STRATEGY=daily
# WIKI_LLM_API_KEY=your_wiki_llm_api_key_here
# WIKI_LLM_MODEL=ark-code-latest
# WIKI_LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
# WIKI_LLM_TEMPERATURE=0.7
# WIKI_LLM_MAX_TOKENS=2000
# WIKI_LLM_RETRY_TIMES=3
WIKI_AUTO_PROCESS=true
WIKI_AUTO_IMPORT_WIKI=false
WIKI_FILE_MONITOR_ENABLED=false
WIKI_FILE_MONITOR_INTERVAL=5
